import { 
  FileEdit, 
  PlusSquare, 
  Users, 
  CheckCircle, 
  Clock, 
  AlertCircle,
  ArrowRight,
  TrendingUp,
  MoreVertical,
  Layers,
  Search,
  BookOpen,
  PlayCircle
} from 'lucide-react';
import { useTeacherStats, useManagedContent } from '@/lib/query/hooks/useTeacher';
import { cn } from '@/lib/utils';
import Link from 'next/link';

export default function TeacherDashboardPage() {
  const { data: stats, isLoading: isStatsLoading } = useTeacherStats();
  const { data: recentContent, isLoading: isContentLoading } = useManagedContent();

  return (
    <div className="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
      {/* Header Profile Section */}
      <div className="flex flex-col md:flex-row justify-between gap-6 p-8 bg-gradient-to-r from-slate-900 to-slate-800 rounded-3xl text-white shadow-xl relative overflow-hidden h-fit">
         <div className="absolute top-0 right-0 -mr-16 -mt-16 text-slate-700/30">
            <TrendingUp size={200} strokeWidth={1.5} />
         </div>
         <div className="relative z-10 flex flex-col gap-2 max-w-xl">
             <div className="inline-flex items-center gap-1.5 w-fit px-3 py-1 rounded-full bg-blue-500/20 border border-blue-400/30 text-[11px] font-black uppercase tracking-wider text-blue-200 mb-2">
                 <CheckCircle size={14} /> Teacher Dashboard
             </div>
             <h1 className="text-3xl md:text-4xl font-extrabold tracking-tight">Chào mừng trở lại!</h1>
             <p className="text-slate-300 font-medium leading-relaxed">
                 Tóm tắt tình hình các bài giảng của bạn và tổng quan hiệu suất trong học kỳ này.
             </p>
         </div>
         <div className="relative z-10 flex flex-wrap gap-3 mt-4 md:mt-0 lg:my-auto">
             <Link href="/teacher/content" className="bg-white/10 w-fit hover:bg-white/20 border border-white/10 px-5 py-2.5 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 active:scale-95 shadow-sm whitespace-nowrap">
                Quản lý Nội dung <ArrowRight size={16} />
             </Link>
         </div>
      </div>

      {/* Stats Cards Dashboard */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { label: 'Học sinh đang học',    value: isStatsLoading ? '...' : stats?.activeStudents || 0,        icon: Users,        color: 'text-blue-600',    bg: 'bg-blue-50',    border: 'border-blue-100', trend: '+12% so với tháng trước' },
          { label: 'Số tài liệu Bài giảng',value: isStatsLoading ? '...' : stats?.totalLessons || 0,          icon: BookOpen,      color: 'text-amber-600',   bg: 'bg-amber-50',   border: 'border-amber-100', trend: 'Tăng trưởng đều' },
          { label: 'Số Quizzes đã tạo',    value: isStatsLoading ? '...' : stats?.totalQuizzes || 0,          icon: PlayCircle,    color: 'text-purple-600',  bg: 'bg-purple-50',  border: 'border-purple-100', trend: 'Lý tưởng' },
          { label: 'Chờ xét duyệt',        value: isStatsLoading ? '...' : stats?.pendingReviews || 0,     icon: Clock,        color: 'text-rose-600',      bg: 'bg-rose-50',      border: 'border-rose-100', trend: 'Nội dung Pending' },
        ].map((stat, i) => (
          <div key={i} className="bg-white rounded-2xl p-5 border border-slate-200 shadow-sm flex flex-col justify-between hover:-translate-y-1 transition-transform group">
            <div className="flex items-start justify-between gap-4 mb-4">
               <div>
                 <p className="text-[12px] font-bold text-slate-500 uppercase tracking-tight">{stat.label}</p>
                 <p className="text-3xl font-black text-slate-800 mt-1">{stat.value}</p>
               </div>
               <div className={cn("p-3 rounded-xl transition-colors border", stat.bg, stat.color, stat.border)}>
                 <stat.icon size={22} className="group-hover:scale-110 transition-transform" />
               </div>
            </div>
            <div className="text-xs font-semibold text-slate-400 flex items-center gap-1.5 pt-4 border-t border-slate-50">
                <TrendingUp size={13} className={stat.color} /> {stat.trend}
            </div>
          </div>
        ))}
      </div>
      
      {/* 2 Column Layout -> Main Action / Recent Works */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div className="lg:col-span-2 space-y-6">
           <div className="flex items-center justify-between">
              <h2 className="text-xl font-extrabold text-slate-800 flex items-center gap-2">
                 <Clock size={20} className="text-slate-400" /> Cập nhật gần đây
              </h2>
              <Link href="/teacher/content" className="text-sm font-bold text-blue-600 hover:text-blue-700 bg-blue-50 px-3 py-1 rounded-lg">Xem tất cả</Link>
           </div>
           
           <div className="bg-white border text-center border-slate-200 rounded-2xl overflow-hidden shadow-sm">
             <table className="w-full text-left">
               <thead>
                 <tr className="bg-slate-50/80 text-slate-500 text-[11px] uppercase tracking-wider font-extrabold border-b border-slate-200">
                   <th className="px-5 py-4">Tên nội dung</th>
                   <th className="px-5 py-4 text-center">Phân loại</th>
                   <th className="px-5 py-4 text-center">Trạng thái</th>
                   <th className="px-5 py-4 text-right">Hành động</th>
                 </tr>
               </thead>
               <tbody className="divide-y divide-slate-100">
                 {isContentLoading || !recentContent ? (
                    <tr>
                        <td colSpan={4} className="p-8 text-center text-slate-400 font-medium hover:bg-slate-50 transition-colors">
                            Đang tải cập nhật gần đây từ máy chủ nội dung...
                        </td>
                    </tr>
                 ) : recentContent.length === 0 ? (
                    <tr>
                        <td colSpan={4} className="p-8 text-center text-slate-500 font-medium">Hệ thống chưa ghi nhận bài viết nào của bạn. Giao diện này sẽ liệt kê những nội dung bạn mới tương tác gần đây.</td>
                    </tr>
                 ) : recentContent.slice(0, 5).map((item) => (
                   <tr key={item.id} className="group hover:bg-slate-50/80 transition-colors">
                     <td className="px-5 py-4 font-bold text-slate-700 text-sm overflow-hidden text-ellipsis whitespace-nowrap max-w-[200px]">{item.title}</td>
                     <td className="px-5 py-4 text-center">
                        <span className={`capitalize text-[10px] uppercase tracking-wider font-black px-2.5 py-1 rounded-md border ${
                             item.type === 'LESSON' ? 'bg-blue-50 text-blue-600 border-blue-100' :
                             item.type === 'QUIZ' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' :
                             'bg-purple-50 text-purple-600 border-purple-100'
                         }`}>
                           {item.type}
                        </span>
                     </td>
                     <td className="px-5 py-4">
                        <div className="flex justify-center">
                       {item.status === 'APPROVED' ? (
                           <div className="flex items-center gap-1.5 text-xs font-bold text-emerald-600 bg-emerald-50 border border-emerald-100 px-2 py-0.5 rounded-md">
                               <CheckCircle size={14} /> Approved
                           </div>
                       ) : item.status === 'PENDING' ? (
                           <div className="flex items-center gap-1.5 text-xs font-bold text-amber-600 bg-amber-50 border border-amber-100 px-2 py-0.5 rounded-md">
                               <Clock size={14} /> Pending
                           </div>
                       ) : item.status === 'REJECTED' ? (
                           <div className="flex items-center gap-1.5 text-xs font-bold text-rose-600 bg-rose-50 border border-rose-100 px-2 py-0.5 rounded-md">
                               <AlertCircle size={14} /> Rejected
                           </div>
                       ) : (
                           <div className="flex items-center gap-1.5 text-xs font-bold text-slate-600 bg-slate-100 border border-slate-200 px-2 py-0.5 rounded-md">
                               <FileEdit size={14} /> Draft
                           </div>
                       )}
                        </div>
                     </td>
                     <td className="px-5 py-4 text-right">
                        <div className="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                             <button className="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors border border-transparent hover:border-blue-100 shadow-none hover:shadow-sm bg-white"><FileEdit size={16} /></button>
                             <button className="p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors border border-transparent hover:border-slate-200 shadow-none hover:shadow-sm bg-white"><MoreVertical size={16} /></button>
                        </div>
                     </td>
                   </tr>
                 ))}
               </tbody>
             </table>
           </div>
        </div>

        {/* Quick Create Actions */}
        <div className="space-y-6">
             <h2 className="text-xl font-extrabold text-slate-800 flex items-center gap-2">
                 <PlusSquare size={20} className="text-slate-400" /> Khởi tạo nhanh
             </h2>
             <div className="bg-white border border-slate-200 rounded-2xl p-2 space-y-2 shadow-sm">
                 <Link href="/teacher/lessons/build" className="flex items-center gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors group border border-transparent hover:border-slate-200">
                    <div className="w-12 h-12 bg-blue-50 border border-blue-100 text-blue-600 rounded-xl flex flex-shrink-0 items-center justify-center group-hover:scale-105 transition-transform"><BookOpen size={22} /></div>
                    <div>
                        <h3 className="font-bold text-slate-800 text-sm">Soạn Bài giảng mới</h3>
                        <p className="text-xs text-slate-500 font-medium mt-0.5">Lý thuyết, Trắc nghiệm, File PDF</p>
                    </div>
                 </Link>
                 <Link href="/teacher/quizzes/build" className="flex items-center gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors group border border-transparent hover:border-slate-200">
                    <div className="w-12 h-12 bg-emerald-50 border border-emerald-100 text-emerald-600 rounded-xl flex flex-shrink-0 items-center justify-center group-hover:scale-105 transition-transform"><PlayCircle size={22} /></div>
                    <div>
                        <h3 className="font-bold text-slate-800 text-sm">Tạo Quiz & Đề thi</h3>
                        <p className="text-xs text-slate-500 font-medium mt-0.5">Đặt thời gian, Ngân hàng câu hỏi</p>
                    </div>
                 </Link>
                 <Link href="/teacher/combos/build" className="flex items-center gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors group border border-transparent hover:border-slate-200">
                    <div className="w-12 h-12 bg-purple-50 border border-purple-100 text-purple-600 rounded-xl flex flex-shrink-0 items-center justify-center group-hover:scale-105 transition-transform"><Layers size={22} /></div>
                    <div>
                        <h3 className="font-bold text-slate-800 text-sm">Đóng gói Lộ trình</h3>
                        <p className="text-xs text-slate-500 font-medium mt-0.5">Tạo chuỗi bài giảng combo</p>
                    </div>
                 </Link>
             </div>
        </div>
      </div>
    </div>
  );
}
